# Mistral OCR (required for upload extraction)
MISTRAL_OCR_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest

# OpenRouter (chat, summaries, grammar, and assistant features)
OPENROUTER_API_KEY=

# Model routing
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash
OPENROUTER_CHAT_MAX_TOKENS=1200
OPENROUTER_GRAMMAR_MODEL=
OPENROUTER_GRAMMAR_MAX_TOKENS=2000

# Post-extraction grammar pass — off by default (user-triggered via /api/pdf/fix-grammar only)
OPENROUTER_AUTO_GRAMMAR_FIX=false

# Legacy OpenRouter full-file extraction fallback — off by default
ENABLE_FULL_FILE_MULTIMODAL_FALLBACK=false

# PDF OCR route — dev/manual only unless explicitly enabled
ENABLE_PDF_OCR_ROUTE=false

# Large parsed-text chunk batching for legacy paths
MAX_CHUNKS_PER_BATCH=40
MAX_INPUT_CHARS_PER_BATCH=60000

# Server page-preview cache (optional — off until /api/pdf/page-preview is implemented)
NEXT_PUBLIC_ENABLE_SERVER_PAGE_PREVIEW=false

# Product analytics (optional; enables signup/upgrade conversion metrics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=

# Convex durable extraction storage (optional — local .data cache works without these)
NEXT_PUBLIC_CONVEX_URL=
EXTRACTION_STORAGE_SECRET=
CRON_SECRET=
ADMIN_EMAIL=mousab.r@gmail.com,mousab.r@me.com
USAGE_LEDGER_SECRET=
QUOTA_ENFORCEMENT_ENABLED=true

# Upload limits
MAX_SERVER_UPLOAD_BYTES=524288000
NEXT_PROXY_CLIENT_MAX_BODY_SIZE=500mb

# Performance instrumentation
# Web Vitals reporting is off by default. Enable both flags to emit structured
# performance logs from /api/performance/web-vitals and upload timing.
NEXT_PUBLIC_ENABLE_WEB_VITALS_REPORTING=false
PERFORMANCE_LOGGING_ENABLED=false

# Clerk auth (required for sign-in + Convex client auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Convex auth — set on the Convex deployment (Dashboard → Settings → Environment Variables)
# CLERK_JWT_ISSUER_DOMAIN=https://clerk.drnote.co
# CLERK_JWT_ISSUER_DOMAIN_DEV=https://your-app.clerk.accounts.dev
# Create a Clerk JWT template named "convex" with audience "convex".

# Admin bypass — comma-separated Clerk user IDs get pro access without billing
ADMIN_CLERK_USER_IDS=

# Point Clerk Dashboard → Webhooks → https://drnote.co/api/webhooks/clerk
CLERK_WEBHOOK_SIGNING_SECRET=

# Clerk Billing (subscriptions)
# Configure these plan slugs in the Clerk Dashboard Billing plans page.
# Max and Teams currently map to the high-tier Convex quota profile.
NEXT_PUBLIC_CLERK_BILLING_HIGHLIGHTED_PLAN=pro
CLERK_BILLING_PRO_PLAN=pro
CLERK_BILLING_MAX_PLAN=max
CLERK_BILLING_TEAMS_PLAN=teams
CLERK_BILLING_STARTER_PLAN=starter

# Clerk Billing Features — create matching Features in Clerk Dashboard and attach to Plans.
# Use has({ feature }) / <Show when={{ feature }}> to gate paid UI; enforce on API routes too.
CLERK_FEATURE_PAID_ACCESS=paid_access
CLERK_FEATURE_ADVANCED_STUDY=advanced_study

# Durable extraction worker
# Convex Cron calls this URL every 2 minutes to recover queued/stale extraction jobs.
EXTRACTION_WORKER_URL=https://www.drnote.co/api/pdf/mcqs/worker
EXTRACTION_WORKER_STALE_AFTER_MS=120000

# Cloudflare R2 (Convex env vars; do not expose these to the Next.js client)
CLOUDFLARE_ACCOUNT_ID=5000e0a4f0ca6dd90b08bde9dc11ccb9
R2_BUCKET=drnote-uploads-prod
R2_OBJECT_PREFIX=prod
R2_ENDPOINT=https://5000e0a4f0ca6dd90b08bde9dc11ccb9.r2.cloudflarestorage.com
R2_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Chat fallback if OpenRouter key is unset
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
